{
  "name": "jasd",
  "version": "0.1.0",
  "description": "JASD — Just A Simple Downloader",
  "main": "main/index.js",
  "author": "MaRcR11",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "format": "prettier --write \"main/**/*.js\" \"src/**/*.js\" \"src/**/*.css\" \"src/**/*.html\"",
    "format:check": "prettier --check \"main/**/*.js\" \"src/**/*.js\" \"src/**/*.css\" \"src/**/*.html\""
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.jasd.downloader",
    "productName": "JASD",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/",
      "category": "Video"
    }
  }
}
